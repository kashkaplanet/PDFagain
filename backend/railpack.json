{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "22"
  },
  "aptPackages": [
    "git",
    "chromium",
    "libnss3",
    "libfreetype6",
    "libharfbuzz0b",
    "libfontconfig1",
    "libcairo2",
    "libpango-1.0-0",
    "libglib2.0-0",
    "libdbus-1-3",
    "libatk1.0-0",
    "libcups2",
    "libdrm2",
    "libexpat1",
    "libnspr4",
    "libx11-6",
    "libxcomposite1",
    "libxdamage1",
    "libxext6",
    "libxfixes3",
    "libxrandr2",
    "libxcb1",
    "libasound2",
    "libatk-bridge2.0-0",
    "libgtk-3-0",
    "libuuid1",
    "fonts-liberation",
    "fonts-noto-color-emoji"
  ],
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "deploy": {
    "startCommand": "npm start"
  }
}
